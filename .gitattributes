# Normalize text files.
* text=auto

# Unity YAML assets should stay readable in diffs.
*.anim text eol=lf
*.asset text eol=lf
*.controller text eol=lf
*.mat text eol=lf
*.meta text eol=lf
*.overrideController text eol=lf
*.prefab text eol=lf
*.unity text eol=lf

# Source/config files.
*.asmdef text eol=lf
*.asmref text eol=lf
*.cginc text eol=lf
*.compute text eol=lf
*.cs text diff=csharp eol=lf
*.hlsl text eol=lf
*.json text eol=lf
*.shader text eol=lf
*.txt text eol=lf
*.uxml text eol=lf
*.uss text eol=lf
*.xml text eol=lf
*.yaml text eol=lf
*.yml text eol=lf

# Binary art, audio, model, archive, and plugin files belong in Git LFS.
*.3ds filter=lfs diff=lfs merge=lfs -text
*.7z filter=lfs diff=lfs merge=lfs -text
*.a filter=lfs diff=lfs merge=lfs -text
